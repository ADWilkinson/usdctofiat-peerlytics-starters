# ── USDCtoFiat ────────────────────────────────────────────────────
# Private key for deposit creation/withdrawal (hex, 0x-prefixed)
# PRIVATE_KEY=0x...

# Wallet address for read-only deposit listing
# WALLET_ADDRESS=0x...

# create-deposit.ts defaults
PLATFORM=revolut
CURRENCY=USD
IDENTIFIER=demo
AMOUNT=10

# ── Peerlytics ────────────────────────────────────────────────────
# API key (required for most peerlytics scripts)
# Generate one at https://peerlytics.xyz/developers?tab=account
# Each key includes 1,000 free requests/month
PEERLYTICS_API_KEY=pk_live_

# rate-monitor.ts
# CURRENCY=GBP
THRESHOLD=1.02
POLL_SECONDS=60

# orderbook-snapshot.ts
CURRENCIES=GBP,EUR,BRL,TRY,NGN

# live-activity.ts
# EVENT_TYPE=fill
