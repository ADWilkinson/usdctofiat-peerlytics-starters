  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "viem": {
      "ws": "8.21.0"
    },
    "tsx": {
      "esbuild": "0.28.1"
